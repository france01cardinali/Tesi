{
  "name": "configuratore-tirocinio",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:https:local": "ng serve --host 0.0.0.0 --port 4200 --ssl --ssl-cert ssl\\localhost+2.pem --ssl-key ssl\\localhost+2-key.pem",
    "backend:https:local": "set HTTPS_KEY_PATH=ssl\\localhost+2-key.pem&& set HTTPS_CERT_PATH=ssl\\localhost+2.pem&& set HTTPS_ONLY=true&& node backend/server.js",
    "start:https:mob": "ng serve --host 0.0.0.0 --port 4200 --ssl --ssl-cert ssl\\10.46.123.138.pem --ssl-key ssl\\10.46.123.138-key.pem",
    "backend:https:mob": "set HTTPS_KEY_PATH=ssl\\10.46.123.138-key.pem&& set HTTPS_CERT_PATH=ssl\\10.46.123.138.pem&& set HTTPS_ONLY=true&& node backend/server.js",
    "backend": "node backend/server.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
